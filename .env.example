# LogisX environment template.
# Copy this file to .env and fill in real values. The live .env is git-ignored;
# this template is checked in so the team knows which keys exist.

# --- Server ---
PORT=3000
SESSION_SECRET=change-me-in-production

# --- Parallel-dev port overrides (per-worktree, optional) ---
# When running multiple worktrees side-by-side, give each its own ports.
# VITE_DEV_PORT is the Vite dev server port; VITE_API_TARGET is the Express
# backend that Vite proxies /api and /socket.io to. Leave both unset for the
# default 5173 → http://localhost:3000 pairing.
# VITE_DEV_PORT=5173
# VITE_API_TARGET=http://localhost:3000

# --- Google Sheets / Drive / Maps ---
# Spreadsheet IDs. Leave unset to use the production sheets; override in
# staging (or any non-prod env) to point at a separate copy. The service
# account (sheets-bot@logistics-app-491014.iam.gserviceaccount.com) must be
# shared on whichever sheet you point at.
SPREADSHEET_ID=
ARCHIVE_SPREADSHEET_ID=
# Drive folder ID for POD uploads. Optional — uploads skip Drive when empty.
GOOGLE_DRIVE_FOLDER_ID=
# Required for the dashboard maps, route directions, and geocoding.
GOOGLE_MAPS_API_KEY=

# --- Email (driver onboarding + investor outreach) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Gemini Vision (expense receipt OCR) ---
# Optional. When unset, the receipt-OCR endpoint returns 503 and the driver
# form silently falls back to manual entry.
GEMINI_API_KEY=
GEMINI_OCR_MODEL=gemini-2.5-flash

# --- Routemate ELD/telematics integration ---
# Base URL is the production Routemate cloud. Override only for sandbox use.
ROUTEMATE_BASE_URL=https://cloud.routemate.ai
# Issued by Routemate. Sent as the X-Api-Key header on every request.
ROUTEMATE_API_KEY=
# Master kill switch. Leave false until the API key is wired and at least one
# truck is linked to a Routemate vehicle. When false, all sync intervals are
# dormant and the manual probe (POST /api/admin/routemate/sync-now) returns 503.
ROUTEMATE_ENABLED=false
# Polling cadences (used in Phase 2+; harmless when ROUTEMATE_ENABLED=false).
ROUTEMATE_POLL_LIVE_SEC=60
ROUTEMATE_POLL_FAULTS_SEC=300
ROUTEMATE_POLL_DAILY_HOUR=4

# --- ScanKit.io document scanning ---
# Powers the document scanner (driver POD/BOL, expense receipts, admin uploads)
# via POST /api/documents/scan — server-side only, never exposed to the client.
# Base URL is the production ScanKit API; override only for sandbox use.
SCANKIT_BASE_URL=https://api.scankit.io
# Issued by ScanKit (format sk_...). Sent as the Authorization: Bearer header.
SCANKIT_API_KEY=
# Master kill switch. Leave false until the API key is wired. When false (or the
# key is unset), POST /api/documents/scan returns 503 and the client scanner
# falls back to attaching the raw photo (receipts simply skip enhancement).
SCANKIT_ENABLED=false
# ScanKit is credit-billed: charged per successful scan (HTTP 2xx); 4xx errors
# like 402 are NOT billed and NOT retried. When credits run out the scan endpoint
# returns 402 and the driver app falls back to attaching the raw photo — the POD
# still uploads, just without crop/deskew/lighting enhancement. Setting
# SCANKIT_ENABLED=false fully disables scanning (endpoint returns 503 + the same
# raw-photo fallback). Recovery / credit top-up / key-rotation runbook:
# docs/runbooks/scankit-billing.md
