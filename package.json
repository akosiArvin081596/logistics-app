{
  "name": "google-sheets-crud",
  "version": "1.0.0",
  "description": "Node.js CRUD app using Google Sheets as a database",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ext js server.js",
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm run build",
    "postinstall": "cd client && npm install"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "better-sqlite3-session-store": "^0.1.0",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "googleapis": "^128.0.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
